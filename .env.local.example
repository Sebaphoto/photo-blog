# Supabase — prendi questi da https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGci...

# NextAuth — genera con: openssl rand -base64 32
NEXTAUTH_SECRET=genera_una_stringa_casuale_sicura
NEXTAUTH_URL=http://localhost:3000

# Il tuo account admin (email usata su Supabase Auth)
ADMIN_EMAIL=tua@email.com
